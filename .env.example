# Optional local environment file.
# Copy to .env only for local use. Never commit .env.

# Optional external gateway defaults for provider=futu / provider=ibkr examples.
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
IBKR_HOST=127.0.0.1
IBKR_PORT=7497

# Optional runtime tuning for large local parameter matrices.
LO2CIN4BT_MATRIX_WORKERS=4
LO2CIN4BT_MATRIX_RESULT_RETENTION=100
