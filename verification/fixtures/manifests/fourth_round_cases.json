{
  "batch_id": "fourth_round",
  "description": "Fourth-round truth validation focused on richer backtester combinations and real-config WFA parity.",
  "cases": [
    {
      "id": "backtester_ma1_hl1_combo",
      "module": "backtester",
      "compare_mode": "candidate_only_truth",
      "enabled": true,
      "description": "AND combo with MA1 and HL1 entry, MA4 exit, using compact daily file fixture.",
      "config": {
        "dataloader": {
          "source": "file",
          "frequency": "1d",
          "start_date": "2024-01-17",
          "file_config": {
            "file_path": "${FIXTURE_ROOT}/backtester/mini_ohlc_truth.csv",
            "time_column": "Time",
            "time_format": "%Y-%m-%d",
            "open_column": "Open",
            "high_column": "High",
            "low_column": "Low",
            "close_column": "Close",
            "volume_column": "Volume"
          },
          "predictor_config": {
            "skip_predictor": true
          }
        },
        "backtester": {
          "strategy_mode": "semantic",
          "strategy_contract_path": "${FIXTURE_ROOT}/backtester/strategy-mini-price-timer.json",
          "engine_mode": "auto",
          "selected_predictor": "X",
          "trading_params": {
            "transaction_cost": 0.0,
            "slippage": 0.0,
            "trade_delay": 1,
            "trade_price": "open",
            "execution_backend": "python_numba"
          },
          "export_config": {
            "export_csv": false,
            "export_excel": false,
            "output_dir": "${OUTPUT_ROOT}/records/backtester"
          }
        },
        "metricstracker": {
          "enable_metrics_analysis": false
        }
      },
      "expected_truth": {
        "resolved_engine_mode": "node_ir",
        "expected_rows": 8,
        "required_columns": [
          "Time",
          "Trade_action",
          "Open_position_price",
          "Close_position_price",
          "Holding_period_count",
          "Position_size",
          "strategy_mode"
        ],
        "expected_nonzero_trade_actions": 3,
        "entry_row": {
          "Time": "2024-01-20",
          "Trade_action": 1,
          "Open_position_price": 103.0,
          "Position_size": 1.0
        },
        "exit_row": {
          "Time": "2024-01-22",
          "Trade_action": 4,
          "Close_position_price": 105.0,
          "Position_size": 0.0
        }
      }
    },
