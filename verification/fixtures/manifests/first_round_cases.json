          "resolved_engine_mode": "node_ir",
          "expected_rows": 8,
          "required_columns": [
            "Time",
            "Trade_action",
            "Open_position_price",
            "Close_position_price",
            "Holding_period_count",
            "Position_size",
            "strategy_mode"
          ],
          "expected_nonzero_trade_actions": 3,
          "entry_row": {
            "Time": "2024-01-20",
            "Trade_action": 1,
