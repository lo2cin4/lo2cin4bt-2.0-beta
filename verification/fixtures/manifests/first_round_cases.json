          "engine_mode": "auto",
          "selected_predictor": "X",
          "trading_params": {
            "transaction_cost": 0.0,
            "slippage": 0.0,
            "trade_delay": 1,
            "trade_price": "open",
            "execution_backend": "python_numba"
          },
          "export_config": {
            "export_csv": false,
            "export_excel": false,
