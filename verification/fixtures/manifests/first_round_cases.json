      "expected_truth": {
        "resolved_engine_mode": "node_ir",
        "expected_rows": 9,
        "required_columns": [
          "Time",
          "Trade_action",
          "Open_position_price",
          "Close_position_price",
          "Holding_period_count",
          "Position_size",
          "strategy_mode"
        ],
        "expected_nonzero_trade_actions": 1,
        "entry_row": {
          "Time": "2024-01-24",
          "Trade_action": 1,
          "Open_position_price": 103.0,
          "Position_size": 1.0
        }
      }
    },
    {
      "id": "metricstracker_from_ma_case",
