{
  "batch_id": "third_round",
  "description": "Third-round truth validation focused on additional statanalyser coverage and WFA modes.",
  "cases": [
    {
      "id": "statanalyser_stationarity",
      "module": "statanalyser",
      "compare_mode": "old_vs_new",
      "enabled": true,
      "description": "Stationarity analysis on a compact daily trend fixture.",
      "config": {
        "statanalyser": {
          "enabled": true,
          "fixture_dataset": "${FIXTURE_ROOT}/statanalyser/correlation_truth_dataset.csv",
          "target": {
            "predictor_column": "total",
            "return_column": "close_return",
            "diff_mode": "none"
          },
          "tests": {
            "stationarity": {
              "enabled": true,
              "output": [
                "summary"
              ]
            }
          },
          "report": {
            "formats": [
              "json",
              "md"
            ],
            "output_dir": "${OUTPUT_ROOT}/records/statanalyser",
            "include_plots": false,
            "include_raw_tables": false,
            "fail_on_error": true
          }
        }
      }
    },
