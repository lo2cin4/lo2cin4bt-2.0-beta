    {
      "id": "wfa_standard_template",
      "module": "wfa",
      "compare_mode": "candidate_only_truth",
      "enabled": true,
      "description": "WFA standard template parity using the shared autorunner config template.",
      "config": {
        "wfa": {
          "config_name": "wfa_standard_template.json",
          "mode": "standard",
          "inline_config": {
            "wfa_config": {
              "engine": "unified_portfolio",
              "run_id": "wfa_standard_template",
              "windowing": {
                "train_size": 20,
                "test_size": 10,
                "step_size": 10
              },
              "optimization_objectives": [
                "sharpe"
              ],
              "outputs": {
                "output_dir": "${OUTPUT_ROOT}/records/wfanalyser",
                "candidate_diagnostics": true
              }
            },
            "dataloader": {
              "source": "multi_asset"
            },
            "backtester": {
              "strategy_mode": "multi_asset_portfolio",
              "market_data": {
                "close": {
                  "path": "${FIXTURE_ROOT}/wfa/multi_asset_close_truth.csv",
                  "time_column": "Time"
                }
              },
              "portfolio_config": {
                "strategy_id": "wfa_standard_template_strategy",
                "universe": {
                  "symbols": [
                    "AAA",
                    "BBB"
                  ]
                },
                "parameter_domains": {
                  "lookback": [
                    2,
                    4
                  ]
                },
                "features": [
                  {
                    "name": "momentum",
                    "op": "indicator.momentum",
                    "source": "close",
                    "period": {
                      "param_ref": "lookback"
                    }
                  }
                ],
                "rebalance": {
                  "trigger": {
                    "op": "calendar.every_session"
                  }
                },
                "selection": {
                  "eligible": {
                    "field": "close",
                    "op": "gt",
                    "value": 0
                  },
                  "rank_by": "momentum",
                  "rank_order": "desc",
                  "top_n": 1
                },
                "allocation": {
                  "method": "equal_weight",
                  "position_limit": 1.0
                },
                "execution": {
                  "cost": {
                    "transaction_cost": 0.0,
                    "slippage": 0.0
                  }
                }
              }
            },
            "metricstracker": {}
          }
        }
      },
      "expected_truth": {
        "resolved_mode": "standard",
        "window_count": 2,
        "objective_names": [
          "sharpe"
        ],
        "objective_result_counts": {
          "sharpe": 2
        }
      }
    },
