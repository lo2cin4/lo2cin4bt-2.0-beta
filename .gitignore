docs/GITHUB_PUBLICATION.md
docs/GITHUB_RELEASE_CHECKLIST.md
docs/PUBLIC_RELEASE_*.md
docs/refactor/
legacy/

# Source helper scripts belong in this repo even if a parent workspace ignore
# file has a broad scripts/ rule.
!scripts/
!scripts/*.py
!scripts/*.ps1
!scripts/*.sh
!scripts/README.md
scripts/docs_bilingual_audit.py

# Workspace docs and indicator extension code stay in the repo. Runtime configs,
# datasets, strategy/feature examples, and owner-specific examples are local or
# distributed outside GitHub.
!workspace/
!workspace/README.md
!workspace/indicators/
!workspace/indicators/extensions/
!workspace/indicators/extensions/**/
!workspace/indicators/extensions/**/*.py
!workspace/indicators/extensions/**/manifest.json
workspace/indicators/**/__pycache__/
workspace/indicators/**/*.py[cod]
workspace/calendars/**
workspace/datasets/**
workspace/features/**
workspace/features/*.json
workspace/runs/**
workspace/wfa/**
workspace/strategies/**
workspace/strategies/*.json
workspace/statanalyser/**
workspace/**/*.local.json
workspace/**/.local.*

# Public test/verification fixtures are intentionally small and stable. They
# override broad parent ignores for CSV/data-like files.
!tests/fixtures/
!tests/fixtures/**/
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.json
!tests/fixtures/**/*.xlsx
!verification/fixtures/
!verification/fixtures/**/
!verification/fixtures/**/*.md
!verification/fixtures/**/*.json
!verification/fixtures/**/*.csv
!verification/fixtures/**/*.xlsx

# Public README visual assets. These are intentionally allowlisted because the
# parent workspace ignores image and animation extensions by default.
!docs/assets/
!assets/readme/
assets/readme/**
!assets/readme/**/
!assets/readme/.gitkeep
!assets/readme/**/*.png
!assets/readme/**/*.jpg
!assets/readme/**/*.jpeg
!assets/readme/**/*.webp
!assets/readme/**/*.gif
!assets/readme/logos/**/*.svg
!assets/readme/logos/LOGO_SOURCES.md

# Shippori Mincho is bundled locally so the frontend does not depend on a
# network font request at runtime.
!plotter/web/public/fonts/
!plotter/web/public/fonts/shippori-mincho/
!plotter/web/public/fonts/shippori-mincho/*.ttf

# App run artifacts stay out of source control.
outputs/app/run_snapshots/**/*.json

# Internal release-maintenance reports are generated locally and should not be
# published unless a specific summary is promoted to docs/.
outputs/release/
release-validation/
release-validation-*/
clean-clone*/
clean_clone*/
*-clean-clone*/
*-clean_clone*/
*_snapshot/
*_snapshots/
snapshot*/
.screenshots/
screenshots/
captures/
capture-output/
workspace/reports/pre_release/

# Workspace report bodies are local AI / reviewer notes. Keep README anchors so
# users can see where reports belong, but do not publish generated notes.
workspace/reports/**
!workspace/reports/
!workspace/reports/README.md
!workspace/reports/agents/
!workspace/reports/agents/README.md
!workspace/reports/agents/*/
!workspace/reports/agents/*/README.md

# Verification run outputs are regenerated by verification/scripts.
verification/baseline_old/**
verification/candidate_new/**
verification/results/**

# Local reference/runtime files
reference/
/assets/*
!/assets/
!/assets/lo2cin4btneon.jpg
!/assets/readme/
!/assets/readme/**
!/assets/desktop/
!/assets/desktop/**
.project_runtime.json
.project_context.json
