{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lo2cin4bt/app/contracts/page-artifact-matrix-v1.schema.json",
  "title": "lo2cin4bt App Page Artifact Matrix v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_id", "pages"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "contract_id": {"type": "string", "minLength": 1},
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "page_id",
          "required_artifacts",
          "optional_artifacts",
          "blocked_conditions",
          "partial_warning_conditions",
          "fallback_policy"
        ],
        "properties": {
          "page_id": {"type": "string", "minLength": 1},
          "required_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "optional_artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "blocked_conditions": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "partial_warning_conditions": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "fallback_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["allow_ui_rebuild", "notes"],
            "properties": {
              "allow_ui_rebuild": {"type": "boolean"},
              "notes": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
