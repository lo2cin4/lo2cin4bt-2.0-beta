{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lo2cin4bt/contracts/indicator-manifest-v1.schema.json",
  "title": "lo2cin4bt Indicator Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "indicator_id",
    "family_code",
    "name",
    "version",
    "api_version",
    "kind",
    "entry_supported",
    "exit_supported",
    "stateful_execution_required",
    "signal_contract",
    "params_schema",
    "implementation"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "indicator_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.-]+$"
    },
    "family_code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "api_version": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["core", "extension"]
    },
    "category": {
      "type": "string",
      "enum": ["trend", "mean_reversion", "volatility", "structure", "custom"]
    },
    "entry_supported": {
      "type": "boolean"
    },
    "exit_supported": {
      "type": "boolean"
    },
    "stateful_execution_required": {
      "type": "boolean"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supports_multi_source": {
          "type": "boolean",
          "default": false
        },
        "deterministic": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "signal_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value_type", "allowed_values", "semantics"],
      "properties": {
        "value_type": {
          "type": "string",
          "enum": ["int", "float"]
        },
        "allowed_values": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "semantics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["long_open", "short_open", "long_close", "short_close"],
          "properties": {
            "long_open": {"type": "number"},
            "short_open": {"type": "number"},
            "long_close": {"type": "number"},
            "short_close": {"type": "number"}
          }
        }
      }
    },
    "input_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["predictor", "column_params"]
        },
        "required_column_params": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "uniqueItems": true
        },
        "optional_column_params": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "uniqueItems": true
        },
        "description": {
          "type": "string"
        }
      }
    },
    "params_schema": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/paramSpec"
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_backend", "backends"],
      "properties": {
        "default_backend": {
          "type": "string",
          "minLength": 1
        },
        "backends": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/backendSpec"
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lo2cin4bt_min": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "lo2cin4bt_max": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unit_test_path": {"type": "string"},
        "fixture_path": {"type": "string"},
        "smoke_strategy_path": {"type": "string"}
      }
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "team": {"type": "string"},
        "contact": {"type": "string"}
      }
    },
    "license": {
      "type": "string"
    },
    "description": {
      "type": "string"
    }
  },
  "$defs": {
    "paramSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["int", "float", "bool", "string", "enum"]
        },
        "required": {
          "type": "boolean"
        },
        "default": {
          "type": ["number", "string", "boolean", "null"]
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "enum_values": {
          "type": "array",
          "items": {
            "type": ["number", "string", "boolean"]
          },
          "uniqueItems": true
        },
        "description": {
          "type": "string"
        }
      }
    },
    "backendSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend_id", "language", "entrypoint"],
      "properties": {
        "backend_id": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "enum": ["python", "rust", "ffi"]
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1
        },
        "artifact_path": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
