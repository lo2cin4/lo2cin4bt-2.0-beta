{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lo2cin4bt/contracts/strategy-run.schema.json",
  "title": "lo2cin4bt Strategy Run Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "platform",
    "data",
    "universe",
    "allocation",
    "fill_model",
    "risk",
    "parameter_domains",
    "outputs"
  ],
  "properties": {
    "schema_version": {"const": "strategy_run"},
    "platform": {
      "type": "object",
      "required": ["strategy_mode_id", "workflow_id"],
      "properties": {
        "strategy_mode_id": {
          "enum": [
            "single_asset_signal",
            "multi_factor_entry_exit_roles",
            "calendar_event_session",
            "multi_asset_portfolio"
          ]
        },
        "workflow_id": {
          "enum": [
            "single_backtest",
            "parameter_matrix",
            "walk_forward_analysis",
            "rolling_validation",
            "statanalyser"
          ]
        },
        "run_type": {"type": "string"},
        "display_label": {"type": "string"}
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "provider": {"type": ["string", "null"]},
        "frequency": {"type": ["string", "null"]},
        "calendar": {"type": ["string", "null"]},
        "timezone": {"type": ["string", "null"]},
        "start_date": {"type": ["string", "null"]},
        "start_policy": {"type": ["string", "null"]},
        "benchmark": {}
      }
    },
    "universe": {
      "type": "object",
      "required": ["symbols"],
      "properties": {
        "symbols": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "universe_policy": {"type": ["string", "null"]},
        "survivorship_policy": {"type": ["string", "null"]},
        "source_type": {"type": ["string", "null"]},
        "source_kind": {"type": ["string", "null"]},
        "source": {"type": ["string", "null"]},
        "source_ref": {"type": ["string", "null"]},
        "historical_constituents_path": {"type": ["string", "null"]},
        "universe_constituents_path": {"type": ["string", "null"]},
        "constituents_path": {"type": ["string", "null"]},
        "source_path": {"type": ["string", "null"]},
        "universe_path": {"type": ["string", "null"]},
        "as_of_date": {"type": ["string", "null"]},
        "as_of": {"type": ["string", "null"]},
        "historical_constituents_as_of": {"type": ["string", "null"]},
        "universe_constituents_as_of": {"type": ["string", "null"]},
        "delisted_policy": {"type": ["string", "null"]},
        "point_in_time_constituents": {"type": "boolean"},
        "point_in_time": {"type": "boolean"},
        "historical_constituents_hash": {"type": ["string", "null"]},
        "universe_constituents_hash": {"type": ["string", "null"]},
        "constituents_hash": {"type": ["string", "null"]}
      }
    },
    "factor_pipeline": {
      "type": "object",
      "description": "Optional factor-investing pipeline. This is a capability layer shared by single-asset and multi-asset strategies, not a separate engine family.",
      "properties": {
        "schema_version": {"type": ["string", "null"]},
        "external_config_path": {"type": ["string", "null"]},
        "data_requirements": {
          "type": "object",
          "properties": {
            "price_fields": {"type": "array", "items": {"type": "string"}},
            "fundamental_fields": {"type": "array", "items": {"type": "string"}},
            "classification_fields": {"type": "array", "items": {"type": "string"}},
            "alternative_fields": {"type": "array", "items": {"type": "string"}},
            "point_in_time_required": {"type": "boolean"}
          },
          "additionalProperties": true
        },
        "construction": {
          "type": "array",
          "description": "Single-factor or multi-factor construction definitions, such as value, momentum, quality, growth, or volatility.",
          "items": {"type": "object"}
        },
        "preprocessing": {
          "type": "array",
          "description": "Cross-sectional cleanup steps such as winsorize, standardize, neutralize, missing-value policy, and lag audit.",
          "items": {"type": "object"}
        },
        "composite": {
          "type": "object",
          "description": "Multi-factor score construction, such as equal weight, IC weight, regression weight, or ranker output.",
          "additionalProperties": true
        },
        "point_in_time": {
          "type": "object",
          "properties": {
            "known_at_field": {"type": ["string", "null"]},
            "effective_at_field": {"type": ["string", "null"]},
            "lag_policy": {"type": ["string", "null"]},
            "fail_on_lookahead": {"type": "boolean"}
          },
          "additionalProperties": true
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "namespace": {"type": ["string", "null"]},
            "key_fields": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": true
        },
        "outputs": {"type": "object"}
      },
      "additionalProperties": true
    },
    "computed_fields": {
      "type": "array",
      "description": "Public top-level computed indicator/derived-field definitions."
    },
    "signals": {"type": "object"},
    "selection": {"type": "object"},
    "allocation": {"type": "object"},
    "rebalance": {"type": "object"},
    "fill_model": {
      "type": "object",
      "description": "Public top-level fill timing, cost, slippage, and accounting model.",
      "required": [
        "cost"
      ],
      "properties": {
        "timing": {
          "enum": [
            "same_session",
            "bar_offset"
          ]
        },
        "entry_price": {
          "enum": [
            "close",
            "open"
          ]
        },
        "exit_price": {
          "enum": [
            "close",
            "open"
          ]
        },
        "cost": {
          "type": "object",
          "required": [
            "transaction_cost",
            "slippage"
          ],
          "properties": {
            "transaction_cost": {
              "type": "number",
              "minimum": 0
            },
            "slippage": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "accounting_backend": {"type": "string"},
        "session_scope": {
          "enum": [
            "same_session"
          ]
        },
        "same_session_exit": {"type": "boolean"},
        "entry_time": {"type": "string"},
        "exit_time": {"type": "string"},
        "entry_delay_bars": {"type": "integer", "minimum": 0},
        "exit_delay_bars": {"type": "integer", "minimum": 0},
        "matrix_workers": {"type": "integer", "minimum": 1},
        "matrix_result_retention": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "risk": {"type": "object"},
    "parameter_domains": {"type": "object"},
    "combo_limits": {"type": "object"},
    "outputs": {"type": "object"},
    "metadata": {"type": "object"}
  }
}
