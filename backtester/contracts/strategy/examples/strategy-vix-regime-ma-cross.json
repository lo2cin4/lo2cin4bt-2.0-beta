{
  "schema_version": "strategy_contract",
  "strategy_id": "vix_regime_ma_cross_v1",
  "name": "VIX Regime + Trend + MA Cross",
  "description": "Long when VIX < threshold, close > MA200, and MA10 crosses above MA20.",
  "data_context": {
    "primary_instrument": "QQQ",
    "frequency": "1D",
    "timezone": "UTC",
    "calendar": "XNYS",
    "feature_contract_ref": "backtester/contracts/feature/examples/feature-contract-vix-price-v1.json"
  },
  "parameter_domains": {
    "vix_threshold": {"type": "set", "values": [25, 30]},
    "fast_ma": {"type": "set", "values": [10]},
    "slow_ma": {"type": "set", "values": [20]},
    "trend_ma": {"type": "set", "values": [200]}
  },
  "entry": {
    "op": "and",
    "nodes": [
      {
        "op": "lt",
        "left": {"field": "feature.vix.close"},
        "right": {"param_ref": "vix_threshold"}
      },
      {
        "op": "gt",
        "left": {"field": "price.close"},
        "right": {"feature": "ta.sma", "source": "price.close", "params": {"period": {"param_ref": "trend_ma"}}}
      },
      {
        "op": "cross_up",
        "left": {"feature": "ta.sma", "source": "price.close", "params": {"period": {"param_ref": "fast_ma"}}},
        "right": {"feature": "ta.sma", "source": "price.close", "params": {"period": {"param_ref": "slow_ma"}}}
      }
    ]
  },
  "exit": {
    "op": "cross_down",
    "left": {"feature": "ta.sma", "source": "price.close", "params": {"period": {"param_ref": "fast_ma"}}},
    "right": {"feature": "ta.sma", "source": "price.close", "params": {"period": {"param_ref": "slow_ma"}}}
  },
  "engine_preferences": {
    "requested_mode": "auto",
    "allow_hybrid": false,
    "max_combinations": 2000
  }
}
