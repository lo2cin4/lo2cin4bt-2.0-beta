{
  "schema_version": "strategy_run",
  "platform": {
    "strategy_mode_id": "single_asset_signal",
    "workflow_id": "parameter_matrix",
    "run_type": "example",
    "display_label": "Backtest | QQQ | Daily SMA Cross | yfinance | Example"
  },
  "data": {
    "provider": "yfinance",
    "frequency": "1D",
    "interval": "1d",
    "calendar": "XNYS",
    "timezone": "America/New_York",
    "start_date": "2009-01-01",
    "start_policy": "common_available",
    "benchmark": {
      "provider": "yfinance",
      "symbol": "QQQ",
      "label": "QQQ buy and hold",
      "interval": "1d"
    }
  },
  "universe": {
    "symbols": [
      "QQQ"
    ],
    "universe_policy": "single_asset",
    "survivorship_policy": "fixed_single_symbol"
  },
  "computed_fields": [
    {
      "name": "short_ma",
      "op": "indicator.sma",
      "source": "close",
      "period": {
        "param_ref": "short_ma"
      }
    },
    {
      "name": "long_ma",
      "op": "indicator.sma",
      "source": "close",
      "period": {
        "param_ref": "long_ma"
      }
    }
  ],
  "signals": {
    "entry": {
      "field": "short_ma",
      "op": "crosses_above",
      "right_field": "long_ma"
    },
    "exit": {
      "field": "short_ma",
      "op": "crosses_below",
      "right_field": "long_ma"
    },
    "target_weight": 1,
    "conflict_policy": "exit_then_entry"
  },
  "selection": {},
  "allocation": {
    "method": "signal_state",
    "target_weight": 1,
    "cash_policy": "keep_unallocated_cash"
  },
  "rebalance": {
    "trigger": {
      "op": "signal.change"
    }
  },
  "fill_model": {
    "timing": "bar_offset",
    "entry_price": "open",
    "entry_delay_bars": 1,
    "exit_price": "open",
    "exit_delay_bars": 1,
    "cost": {
      "transaction_cost": 0.001,
      "slippage": 0.0005
    },
    "matrix_workers": 8,
    "matrix_result_retention": 50
  },
  "risk": {
    "max_positions": 1,
    "max_gross_exposure": 1,
    "long_short": "long_only",
    "allow_short": false
  },
  "parameter_domains": {
    "short_ma": {
      "type": "range",
      "start": 20,
      "end": 100,
      "step": 10
    },
    "long_ma": {
      "type": "range",
      "start": 120,
      "end": 300,
      "step": 10
    }
  },
  "combo_limits": {
    "warn_combos": 150,
    "hard_cap_combos": 250
  },
  "outputs": {
    "equity_curve": true,
    "trade_summary": true,
    "entry_exit_markers": true,
    "rebalance_audit": true,
    "holdings": true,
    "asset_contribution": true
  },
  "metadata": {
    "example": true,
    "local_research_only": true,
    "strategy_id": "qqq_daily_sma_cross_yfinance_example",
    "notes": [
      "Reference parameter matrix for a daily QQQ SMA cross strategy.",
      "short_ma spans 20 to 100 by 10; long_ma spans 120 to 300 by 10.",
      "This public example is for local research and contract testing only.",
      "It is not a profitability claim, WFA pass, live-trading signal, broker instruction, or investment advice."
    ]
  }
}
