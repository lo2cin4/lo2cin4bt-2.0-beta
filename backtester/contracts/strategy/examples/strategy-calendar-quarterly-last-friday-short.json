{
  "schema_version": "strategy_contract",
  "strategy_id": "calendar.quarterly_last_friday_short",
  "name": "QQQ quarterly last-Friday same-session short",
  "description": "Short QQQ at the session open on the last Friday of Mar/Jun/Sep/Dec and cover at the same session close.",
  "tags": ["calendar", "same_session", "single_asset"],
  "data_context": {
    "primary_instrument": "QQQ",
    "frequency": "1D",
    "timezone": "America/New_York",
    "calendar": "XNYS"
  },
  "parameter_domains": {},
  "execution": {
    "side": "short",
    "entry_price": "open",
    "exit_price": "close",
    "session_scope": "same_session",
    "same_session_exit": true
  },
  "entry": {
    "op": "calendar.last_weekday_of_month",
    "weekday": "friday",
    "months": [3, 6, 9, 12]
  },
  "exit": {
    "op": "session.same_session_close"
  },
  "engine_preferences": {
    "requested_mode": "auto"
  }
}
