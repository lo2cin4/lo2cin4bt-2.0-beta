{
  "schema_version": "factor_pipeline.v1",
  "data_requirements": {
    "price_fields": ["close", "volume"],
    "fundamental_fields": ["market_cap", "book_value", "net_income", "revenue"],
    "classification_fields": ["sector", "industry"],
    "alternative_fields": [],
    "point_in_time_required": true
  },
  "construction": [
    {
      "name": "value_book_to_market",
      "family": "value",
      "op": "factor.book_to_market",
      "inputs": {"book_value": "fundamental.book_value", "market_cap": "fundamental.market_cap"},
      "known_at": "fundamental.known_at",
      "lag": "reported_lag"
    },
    {
      "name": "momentum_12_1",
      "family": "momentum",
      "op": "factor.price_momentum",
      "inputs": {"close": "price.close", "lookback": 252, "skip_recent": 21}
    },
    {
      "name": "quality_profitability",
      "family": "quality",
      "op": "factor.return_on_equity",
      "inputs": {"net_income": "fundamental.net_income", "book_value": "fundamental.book_value"},
      "known_at": "fundamental.known_at",
      "lag": "reported_lag"
    },
    {
      "name": "low_volatility",
      "family": "volatility",
      "op": "factor.realized_volatility",
      "inputs": {"close": "price.close", "lookback": 126}
    }
  ],
  "preprocessing": [
    {"op": "drop_unavailable", "scope": "cross_section"},
    {"op": "winsorize", "scope": "cross_section", "limits": [0.01, 0.99]},
    {"op": "standardize", "scope": "cross_section", "method": "zscore"},
    {"op": "neutralize", "scope": "cross_section", "group_by": ["sector"], "exposures": ["market_cap"]},
    {"op": "lag_audit", "scope": "point_in_time"}
  ],
  "composite": {
    "method": "equal_weight",
    "inputs": ["value_book_to_market", "momentum_12_1", "quality_profitability", "low_volatility"],
    "output": "composite_factor_score"
  },
  "point_in_time": {
    "known_at_field": "known_at",
    "effective_at_field": "date",
    "lag_policy": "factor_value_must_be_known_before_ranking_date",
    "fail_on_lookahead": true
  },
  "cache": {
    "enabled": true,
    "namespace": "lo2cin4bt.factor_pipeline",
    "key_fields": ["schema_version", "universe", "frequency", "construction", "preprocessing", "composite"],
    "storage": "local_parquet"
  },
  "outputs": {
    "factor_frame": true,
    "clean_factor_frame": true,
    "factor_score_frame": true,
    "data_quality": true,
    "statanalyser": true
  }
}
