{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lo2cin4bt/contracts/factor-pipeline-v1.schema.json",
  "title": "lo2cin4bt Factor Pipeline Config v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "data_requirements",
    "construction",
    "preprocessing",
    "composite",
    "point_in_time",
    "cache",
    "outputs"
  ],
  "properties": {
    "schema_version": {"const": "factor_pipeline.v1"},
    "data_requirements": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "price_fields": {"type": "array", "items": {"type": "string"}},
        "fundamental_fields": {"type": "array", "items": {"type": "string"}},
        "classification_fields": {"type": "array", "items": {"type": "string"}},
        "alternative_fields": {"type": "array", "items": {"type": "string"}},
        "point_in_time_required": {"type": "boolean"}
      }
    },
    "construction": {
      "type": "array",
      "description": "Factor definitions. Examples: value, momentum, quality, growth, volatility, sentiment, liquidity.",
      "items": {
        "type": "object",
        "required": ["name", "op"],
        "additionalProperties": true,
        "properties": {
          "name": {"type": "string"},
          "family": {"type": ["string", "null"]},
          "op": {"type": "string"},
          "inputs": {"type": "object"},
          "known_at": {"type": ["string", "null"]},
          "lag": {"type": ["string", "number", "integer", "null"]}
        }
      }
    },
    "preprocessing": {
      "type": "array",
      "description": "Cross-sectional cleanup and comparability steps.",
      "items": {
        "type": "object",
        "required": ["op"],
        "additionalProperties": true,
        "properties": {
          "op": {
            "enum": [
              "winsorize",
              "standardize",
              "neutralize",
              "rank",
              "fill_missing",
              "lag_audit",
              "drop_unavailable"
            ]
          },
          "scope": {"type": ["string", "null"]},
          "group_by": {"type": ["string", "array", "null"]},
          "fields": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "composite": {
      "type": "object",
      "required": ["method"],
      "additionalProperties": true,
      "properties": {
        "method": {
          "enum": [
            "equal_weight",
            "manual_weight",
            "ic_weight",
            "regression_weight",
            "ranker_model",
            "none"
          ]
        },
        "inputs": {"type": "array", "items": {"type": "string"}},
        "weights": {"type": "object"},
        "output": {"type": ["string", "null"]}
      }
    },
    "point_in_time": {
      "type": "object",
      "required": ["fail_on_lookahead"],
      "additionalProperties": true,
      "properties": {
        "known_at_field": {"type": ["string", "null"]},
        "effective_at_field": {"type": ["string", "null"]},
        "lag_policy": {"type": ["string", "null"]},
        "fail_on_lookahead": {"type": "boolean"}
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {"type": "boolean"},
        "namespace": {"type": ["string", "null"]},
        "key_fields": {"type": "array", "items": {"type": "string"}},
        "storage": {"type": ["string", "null"]}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "factor_frame": {"type": "boolean"},
        "clean_factor_frame": {"type": "boolean"},
        "factor_score_frame": {"type": "boolean"},
        "data_quality": {"type": "boolean"},
        "statanalyser": {"type": "boolean"}
      }
    }
  }
}
